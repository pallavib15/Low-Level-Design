import models.Board;
import models.Color;
import models.Player;
import models.Ship;

import java.util.Random;

public class Game {

    private  int n;
    private Board[][] board;
    private Random rand=new Random();
    private boolean[][] visited;

    private static Game instance;
    private Game(){}

    public static Game getInstance(){
        if(instance==null){
            instance=new Game();
        }
        return instance;
    }



    public Board[][] initGame(int n) {
        board = new Board[n][n];
        this.n = n;
        visited = new boolean[n][n];
        for (int i = 0; i < n; i++) {
            for (int j = 0; j < n; j++) {
                visited[i][j] = false;
            }
        }
        return board;
    }

    public void addShip(int id,int size,int ax,int ay){
        Ship ship = new Ship();
        ship.setId(id);
        ship.setSize(size);
        if(ax<=n/2){
            Player player=new Player();
            player.setWhite(true);
            ship.setPlayer(player);
        }else{
            Player player=new Player();
            player.setWhite(false);
            ship.setPlayer(player);
        }
        board[ax][ay].setShip(ship);
    }

    public boolean startGame(Board[][] board, boolean isWhite)
    {

        for(int i=0;i<n;i++)
        {
            for(int j=0;j<n;j++)
            {
                Ship ship=board[i][j].getShip();
                if(ship.getPlayer().isWhite()==isWhite){
                    int x= rand.nextInt(n/2,n);
                    int y= rand.nextInt();
                    Ship sh=board[x][y].getShip();
                    visited[x][y]=true;
                    board[i][j].setShip(null);
                    if(sh!=null && sh.getPlayer().isWhite()!=isWhite){
                        System.out.println("Player "+(isWhite?"A":"B")+"missile fired at"+x+"\t"+y+"Hit");
                    }else{
                        System.out.println("Player "+(isWhite?"A":"B")+"missile fired at"+x+"\t"+y+"Miss");
                    }
                }
            }
        }

        for(int i=0;i<n;i++)
        {
            for(int j=0;j<n;j++)
            {
                if(visited[i][j]==false)
                    return false;
            }
        }

        return true;
    }

    public  void viewGame(){
        for(int i=0;i<n;i++){
            for(int j=0;j<n;j++){
                System.out.print(board[i][j].getShip().getSize());
            }
        }
    }






}


import models.Board;

//TIP To <b>Run</b> code, press <shortcut actionId="Run"/> or
// click the <icon src="AllIcons.Actions.Execute"/> icon in the gutter.
void main() {
    //TIP Press <shortcut actionId="ShowIntentionActions"/> with your caret at the highlighted text
    // to see how IntelliJ IDEA suggests fixing it.

    Game game=Game.getInstance();
   Board[][] boards= game.initGame(6);
    game.addShip(1,4,1,0);
    game.addShip(2,4,0,1);
    game.addShip(3,4,1,1);
    game.addShip(4,4,1,2);
    game.addShip(5,4,1,3);
    game.addShip(6,4,1,4);
    game.addShip(7,4,1,5);
    game.addShip(8,4,0,3);
    game.addShip(9,4,0,5);
    game.addShip(10,4,5,0);
    game.addShip(11,4,5,1);
    game.addShip(12,4,5,2);
    game.addShip(13,4,5,3);
    game.addShip(14,4,5,4);
    game.addShip(15,4,5,5);
    game.addShip(16,4,5,6);
    game.addShip(17,4,4,2);
    game.addShip(18,4,4,0);
    game.addShip(19,4,4,5);
    boolean isWhite=true;
    while(true) {
        if (!game.startGame(boards,isWhite )){
            if(isWhite) {
                isWhite=false;
            }else{
                isWhite=true;
            }
        }else{break;}

    }




}
package models;

public class Ship {

    private int Id;
    private Color color;
    private int size;
    private Player player;



    public Player getPlayer() {
        return player;
    }

    public void setPlayer(Player player) {
        this.player = player;
    }

    public int getId() {
        return Id;
    }

    public void setId(int id) {
        Id = id;
    }

    public Color getColor() {
        return color;
    }

    public void setColor(Color color) {
        this.color = color;
    }

    public int getSize() {
        return size;
    }

    public void setSize(int size) {
        this.size = size;
    }
}
package models;

public class Player {

    private boolean isWhite;

    public Player(){
        this.isWhite = true;
    }

    public boolean isWhite() {
        return isWhite;
    }

    public void setWhite(boolean white) {
        isWhite = white;
    }
}
