📘 Book.java (Only Metadata)
package model;

public class Book {

    private String isbn;
    private String title;
    private String author;
    private BookCategory category;

    public Book(String isbn, String title,
                String author, BookCategory category) {
        this.isbn = isbn;
        this.title = title;
        this.author = author;
        this.category = category;
    }

    public String getIsbn() { return isbn; }
    public String getTitle() { return title; }
    public String getAuthor() { return author; }
    public BookCategory getCategory() { return category; }
}
📕 BookItem.java (Each Physical Copy)
package model;

public class BookItem {

    public enum Status { AVAILABLE, ISSUED }

    private String barcode;
    private Book book;
    private Status status;

    public BookItem(String barcode, Book book) {
        this.barcode = barcode;
        this.book = book;
        this.status = Status.AVAILABLE;
    }

    // Simple synchronized method for thread safety
    public synchronized boolean checkout() {
        if (status == Status.AVAILABLE) {
            status = Status.ISSUED;
            return true;
        }
        return false;
    }

    public synchronized void returnBook() {
        status = Status.AVAILABLE;
    }

    public String getBarcode() { return barcode; }
    public Book getBook() { return book; }
    public Status getStatus() { return status; }
}

👉 Instead of locks, we used synchronized — simpler and clean.

👤 User.java
package model;

import java.time.LocalDate;
import java.util.*;

public class User {

    private String userId;
    private String name;
    private double fine = 0;

    private List<BookItem> issuedBooks = new ArrayList<>();
    private Map<String, LocalDate> borrowedDates = new HashMap<>();

    public User(String userId, String name) {
        this.userId = userId;
        this.name = name;
    }

    public String getUserId() { return userId; }
    public String getName() { return name; }

    public List<BookItem> getIssuedBooks() { return issuedBooks; }
    public Map<String, LocalDate> getBorrowedDates() { return borrowedDates; }

    public double getFine() { return fine; }
    public void addFine(double amount) { fine += amount; }
}
